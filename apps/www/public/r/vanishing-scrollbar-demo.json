{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "vanishing-scrollbar-demo",
  "registryDependencies": [
    "https://deltacomponents.dev/r/vanishing-scrollbar.json"
  ],
  "files": [
    {
      "path": "examples/vanishing-scrollbar-demo.tsx",
      "content": "\"use client\"\n\nimport { VanishingScrollbar } from \"@/components/ui/vanishing-scrollbar\"\n\nconst items = Array.from({ length: 20 }, (_, i) => ({\n  id: i + 1,\n  title: `Item ${i + 1}`,\n  description: `This is the description for item ${i + 1}.`,\n}))\n\nexport default function VanishingScrollbarDemo() {\n  return (\n    <div className=\"flex gap-6\">\n      <div className=\"flex flex-col gap-2\">\n        <p className=\"text-muted-foreground text-sm font-medium\">\n          Smooth fade (default)\n        </p>\n        <VanishingScrollbar className=\"h-64 w-64 rounded-md border p-3\">\n          <div className=\"flex flex-col gap-2\">\n            {items.map((item) => (\n              <div key={item.id} className=\"bg-muted rounded-md p-2\">\n                <p className=\"text-sm font-medium\">{item.title}</p>\n                <p className=\"text-muted-foreground text-xs\">\n                  {item.description}\n                </p>\n              </div>\n            ))}\n          </div>\n        </VanishingScrollbar>\n      </div>\n\n      <div className=\"flex flex-col gap-2\">\n        <p className=\"text-muted-foreground text-sm font-medium\">\n          Instant (no transition)\n        </p>\n        <VanishingScrollbar instant className=\"h-64 w-64 rounded-md border p-3\">\n          <div className=\"flex flex-col gap-2\">\n            {items.map((item) => (\n              <div key={item.id} className=\"bg-muted rounded-md p-2\">\n                <p className=\"text-sm font-medium\">{item.title}</p>\n                <p className=\"text-muted-foreground text-xs\">\n                  {item.description}\n                </p>\n              </div>\n            ))}\n          </div>\n        </VanishingScrollbar>\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}